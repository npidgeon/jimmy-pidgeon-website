---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Contact Jimmy Pidgeon | Speaking & Media Inquiries"
  description="Get in touch with Jimmy Pidgeon for speaking engagements, media inquiries, book questions, or just to connect."
>
  <div class="page-hero">
    <div class="container">
      <h1 class="fade-in-up">Get in Touch</h1>
      <p class="fade-in-up delay-100">
        For speaking engagements, media inquiries, or just to say hello.
      </p>
    </div>
  </div>

  <section class="contact-section section-padding">
    <div class="container">
      <div class="contact-wrapper scroll-reveal">
        <div class="contact-cards">
          <div class="contact-card">
            <div class="icon-wrapper">
              <span class="icon">📧</span>
            </div>
            <h3>Email</h3>
            <p>
              Reach out directly via email for business inquiries, event
              booking, or to ask a question.
            </p>
            <a href="mailto:jimmypidgeon04@gmail.com" class="contact-link"
              >jimmypidgeon04@gmail.com</a
            >
          </div>

          <div class="contact-card">
            <div class="icon-wrapper">
              <span class="icon">📱</span>
            </div>
            <h3>Instagram</h3>
            <p>
              Join the community and follow the daily journey of recovery on
              Instagram.
            </p>
            <a
              href="https://instagram.com/jcp83recovery"
              target="_blank"
              rel="noopener noreferrer"
              class="contact-link"
            >
              @jcp83recovery
            </a>
          </div>

          <div class="contact-card">
            <div class="icon-wrapper">
              <span class="icon">💼</span>
            </div>
            <h3>LinkedIn</h3>
            <p>
              Connect with Jimmy on LinkedIn to network and stay updated on his
              professional journey.
            </p>
            <a
              href="https://www.linkedin.com/in/jimmy-pidgeon-193b08199/"
              target="_blank"
              rel="noopener noreferrer"
              class="contact-link"
            >
              Jimmy Pidgeon
            </a>
          </div>
        </div>

        <div class="contact-note">
          <p>
            <em
              >Please note: Jimmy reads all his messages, but due to volume, it
              may take a few days to receive a response. Thank you for your
              patience and for being part of the journey.</em
            >
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    background: linear-gradient(
      135deg,
      var(--color-primary-dark),
      var(--color-primary)
    );
    color: white;
    padding: calc(80px + var(--space-10)) 0 var(--space-10);
    text-align: center;
  }

  .page-hero h1 {
    color: white;
    margin-bottom: var(--space-2);
  }

  .page-hero p {
    font-size: 1.125rem;
    opacity: 0.9;
    max-width: 600px;
    margin: 0 auto;
  }

  .section-padding {
    padding: var(--space-16) 0;
    min-height: 50vh;
    background-color: var(--color-bg-alt);
    background-image: radial-gradient(var(--color-border) 1px, transparent 1px);
    background-size: 32px 32px;
  }

  .contact-wrapper {
    max-width: 1000px;
    margin: 0 auto;
  }

  .contact-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-6);
    margin-bottom: var(--space-8);
  }

  .contact-card {
    background: var(--color-surface);
    padding: var(--space-8) var(--space-6);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    text-align: center;
    border-top: 4px solid var(--color-primary);
    transition: transform 0.3s ease;
  }

  .contact-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  .icon-wrapper {
    width: 64px;
    height: 64px;
    background: var(--color-bg-alt);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-4);
  }

  .icon {
    font-size: 2rem;
  }

  .contact-card h3 {
    margin-bottom: var(--space-2);
    color: var(--color-text);
  }

  .contact-card p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-bottom: var(--space-6);
  }

  .contact-link {
    display: inline-block;
    font-weight: 600;
    color: var(--color-primary);
    padding: var(--space-2) var(--space-4);
    background: var(--color-bg-alt);
    border-radius: var(--radius);
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .contact-link:hover {
    background: var(--color-primary);
    color: white;
  }

  .contact-note {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    max-width: 600px;
    margin: 0 auto;
  }

  @media (max-width: 640px) {
    .contact-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
