---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Contact Jimmy Pidgeon | Speaking & Media Inquiries"
  description="Get in touch with Jimmy Pidgeon for speaking engagements, media inquiries, book questions, or just to connect."
>
  <div class="page-hero">
    <div class="page-hero-pattern" aria-hidden="true"></div>
    <div class="container">
      <span class="page-label fade-in-up">Let's Connect</span>
      <h1 class="fade-in-up delay-100">Get in Touch</h1>
      <p class="hero-sub fade-in-up delay-200">
        For speaking engagements, media inquiries, or just to say hello.
      </p>
    </div>
  </div>

  <section class="contact-section section-padding">
    <div class="container">
      <div class="contact-wrapper scroll-reveal">
        <div class="contact-cards">
          <!-- Email -->
          <div class="contact-card">
            <div class="icon-wrapper">
              <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
            </div>
            <h3>Email</h3>
            <p>
              Reach out directly for business inquiries, event booking, or to ask a question.
            </p>
            <a href="mailto:jimmypidgeon04@gmail.com" class="contact-btn" id="contact-email-btn">
              jimmypidgeon04@gmail.com
            </a>
          </div>

          <!-- Instagram -->
          <div class="contact-card">
            <div class="icon-wrapper">
              <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
              </svg>
            </div>
            <h3>Instagram</h3>
            <p>
              Join the community and follow the daily journey of recovery.
            </p>
            <a
              href="https://instagram.com/jcp83recovery"
              target="_blank"
              rel="noopener noreferrer"
              class="contact-btn"
              id="contact-instagram-btn"
            >
              @jcp83recovery
            </a>
          </div>

          <!-- LinkedIn -->
          <div class="contact-card">
            <div class="icon-wrapper">
              <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
                <rect x="2" y="9" width="4" height="12"></rect>
                <circle cx="4" cy="4" r="2"></circle>
              </svg>
            </div>
            <h3>LinkedIn</h3>
            <p>
              Connect with Jimmy on LinkedIn to network and stay updated on his journey.
            </p>
            <a
              href="https://www.linkedin.com/in/jimmy-pidgeon-193b08199/"
              target="_blank"
              rel="noopener noreferrer"
              class="contact-btn"
              id="contact-linkedin-btn"
            >
              Jimmy Pidgeon
            </a>
          </div>
        </div>

        <div class="contact-note">
          <p>
            <em>Jimmy reads all his messages personally, but due to volume it may take a few days to respond. Thank you for your patience and for being part of the journey.</em>
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    position: relative;
    background: linear-gradient(135deg, var(--color-primary-dark), hsl(210, 55%, 38%));
    color: white;
    padding: calc(76px + var(--space-10)) 0 var(--space-12);
    text-align: center;
    overflow: hidden;
  }

  .page-hero-pattern {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255,255,255,0.08) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }

  .page-label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-warm-light);
    margin-bottom: var(--space-3);
    opacity: 0;
    animation: fadeInUp 0.8s ease-out forwards;
  }

  .page-hero h1 {
    color: white;
    margin-bottom: var(--space-3);
    position: relative;
  }

  .hero-sub {
    font-size: 1.1rem;
    opacity: 0.85;
    max-width: 480px;
    margin: 0 auto;
    position: relative;
    color: rgba(255,255,255,0.85);
    opacity: 0;
    animation: fadeInUp 0.8s ease-out 200ms forwards;
  }

  .section-padding {
    padding: var(--space-16) 0;
    min-height: 50vh;
    background-color: var(--color-bg-alt);
    background-image: radial-gradient(var(--color-border) 1px, transparent 1px);
    background-size: 32px 32px;
  }

  .contact-wrapper {
    max-width: 1000px;
    margin: 0 auto;
  }

  .contact-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    margin-bottom: var(--space-8);
  }

  .contact-card {
    background: var(--color-surface);
    padding: var(--space-8) var(--space-6);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    text-align: center;
    border-top: 4px solid var(--color-primary);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .contact-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-md);
  }

  .icon-wrapper {
    width: 60px;
    height: 60px;
    background: hsl(210, 50%, 95%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-4);
    color: var(--color-primary);
    transition: background-color 0.25s ease;
  }

  .contact-card:hover .icon-wrapper {
    background: hsl(210, 55%, 90%);
  }

  .contact-card h3 {
    margin-bottom: var(--space-2);
    color: var(--color-text);
    font-size: 1.2rem;
  }

  .contact-card p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-bottom: var(--space-5);
    flex: 1;
    line-height: 1.6;
  }

  /* Clear, prominent contact button */
  .contact-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.6rem 1.25rem;
    background-color: var(--color-primary);
    color: white !important;
    font-weight: 600;
    font-size: 0.875rem;
    border-radius: var(--radius);
    text-decoration: none;
    transition: background-color 0.25s ease, transform 0.2s ease, box-shadow 0.25s ease;
    margin-top: auto;
    word-break: break-all;
    text-align: center;
  }

  .contact-btn:hover {
    background-color: var(--color-primary-dark);
    color: white !important;
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
  }

  .contact-note {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.875rem;
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
  }

  @media (max-width: 900px) {
    .contact-cards {
      grid-template-columns: 1fr;
      max-width: 420px;
      margin-left: auto;
      margin-right: auto;
    }
  }
</style>
