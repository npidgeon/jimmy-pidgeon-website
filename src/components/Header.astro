---
const currentPath = Astro.url.pathname;

const navItems = [
  { name: 'Home', path: '/' },
  { name: 'About', path: '/about' },
  { name: 'Books', path: '/books' },
  { name: 'Contact', path: '/contact' }
];
---

<header class="header">
  <div class="container header-content">
    <a href="/" class="logo">Jimmy Pidgeon</a>
    
    <nav class="desktop-nav">
      <ul>
        {navItems.map((item) => (
          <li>
            <a 
              href={item.path} 
              class={item.path === '/' ? currentPath === '/' ? 'active' : '' : currentPath.startsWith(item.path) ? 'active' : ''}
              aria-current={currentPath === item.path ? 'page' : undefined}
            >
              {item.name}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a 
      href="https://a.co/d/05W2aYn4" 
      target="_blank"
      rel="noopener noreferrer"
      class="header-cta"
      id="header-buy-btn"
    >
      Buy the Book
    </a>
    
    <button class="mobile-menu-btn" aria-label="Toggle menu" aria-expanded="false" id="mobile-menu-btn">
      <span class="bar bar-1"></span>
      <span class="bar bar-2"></span>
      <span class="bar bar-3"></span>
    </button>
  </div>

  <div class="mobile-nav" id="mobile-nav" aria-hidden="true">
    <ul>
      {navItems.map((item) => (
        <li>
          <a 
            href={item.path}
            class={currentPath === item.path ? 'active' : ''}
          >
            {item.name}
          </a>
        </li>
      ))}
    </ul>
    <a 
      href="https://a.co/d/05W2aYn4" 
      target="_blank"
      rel="noopener noreferrer"
      class="mobile-cta"
    >
      Buy the Book →
    </a>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    background-color: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid transparent;
    transition: background-color 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease, height 0.3s ease;
  }

  /* Scrolled state — stronger presence */
  .header.scrolled {
    background-color: rgba(255, 255, 255, 0.97);
    border-bottom-color: var(--color-border);
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.07);
  }

  .header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 76px;
    transition: height 0.3s ease;
  }

  .header.scrolled .header-content {
    height: 64px;
  }
  
  .logo {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-primary-dark);
    text-decoration: none;
    letter-spacing: -0.01em;
    flex-shrink: 0;
  }

  .logo:hover {
    color: var(--color-primary);
  }
  
  .desktop-nav ul {
    list-style: none;
    display: flex;
    gap: var(--space-5);
    margin: 0;
    padding: 0;
  }
  
  .desktop-nav a {
    color: var(--color-text);
    font-weight: 500;
    font-size: 0.95rem;
    position: relative;
    padding-bottom: 4px;
  }
  
  .desktop-nav a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-primary);
    transition: width 0.3s ease;
  }
  
  .desktop-nav a:hover::after,
  .desktop-nav a.active::after {
    width: 100%;
  }
  
  .desktop-nav a.active {
    color: var(--color-primary);
  }

  /* "Buy the Book" CTA in header */
  .header-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background-color: var(--color-warm);
    color: white;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.875rem;
    padding: 0.45rem 1.1rem;
    border-radius: 6px;
    text-decoration: none;
    letter-spacing: 0.01em;
    flex-shrink: 0;
    transition: background-color 0.25s ease, transform 0.2s ease, box-shadow 0.25s ease;
  }

  .header-cta:hover {
    background-color: var(--color-warm-dark);
    color: white;
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(180, 130, 55, 0.35);
  }
  
  .mobile-menu-btn {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    flex-direction: column;
    gap: 5px;
    padding: var(--space-2);
    width: 36px;
    height: 36px;
    align-items: center;
    justify-content: center;
  }
  
  .bar {
    width: 22px;
    height: 2px;
    background-color: var(--color-text);
    transition: all 0.3s ease;
    transform-origin: center;
    display: block;
  }

  /* Hamburger → X animation */
  .mobile-menu-btn.open .bar-1 {
    transform: translateY(7px) rotate(45deg);
  }
  .mobile-menu-btn.open .bar-2 {
    opacity: 0;
    transform: scaleX(0);
  }
  .mobile-menu-btn.open .bar-3 {
    transform: translateY(-7px) rotate(-45deg);
  }
  
  .mobile-nav {
    display: none;
    overflow: hidden;
    background-color: var(--color-surface);
    padding: 0;
    border-top: 1px solid var(--color-border);
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  }
  
  .mobile-nav.open {
    display: block;
    animation: slideDown 0.3s ease-out;
  }
  
  .mobile-nav ul {
    list-style: none;
    padding: var(--space-4) var(--space-6);
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .mobile-nav li {
    border-bottom: 1px solid var(--color-border);
  }

  .mobile-nav li:last-child {
    border-bottom: none;
  }
  
  .mobile-nav a {
    display: block;
    color: var(--color-text);
    font-size: 1rem;
    font-weight: 500;
    padding: var(--space-3) 0;
  }
  
  .mobile-nav a.active {
    color: var(--color-primary);
    font-weight: 600;
  }

  .mobile-cta {
    display: block;
    margin: 0 var(--space-6) var(--space-5);
    padding: var(--space-3) var(--space-5);
    background-color: var(--color-warm);
    color: white !important;
    font-weight: 600;
    text-align: center;
    border-radius: var(--radius);
    font-size: 0.95rem;
    text-decoration: none;
    transition: background-color 0.25s ease;
  }

  .mobile-cta:hover {
    background-color: var(--color-warm-dark);
    color: white !important;
  }
  
  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  @media (max-width: 900px) {
    .header-cta { display: none; }
  }

  @media (max-width: 768px) {
    .desktop-nav { display: none; }
    .mobile-menu-btn { display: flex; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.querySelector('#mobile-menu-btn') as HTMLButtonElement | null;
    const nav = document.querySelector('#mobile-nav') as HTMLElement | null;
    
    if (btn && nav) {
      btn.addEventListener('click', () => {
        const isOpen = nav.classList.toggle('open');
        btn.classList.toggle('open', isOpen);
        btn.setAttribute('aria-expanded', String(isOpen));
        nav.setAttribute('aria-hidden', String(!isOpen));
      });

      // Close on link click
      nav.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          nav.classList.remove('open');
          btn.classList.remove('open');
          btn.setAttribute('aria-expanded', 'false');
          nav.setAttribute('aria-hidden', 'true');
        });
      });
    }
  });
</script>
