---
---

<section class="hero" id="hero">
  <div class="hero-bg">
    <img 
      src="/assets/images/hero_bg.png" 
      alt="Serene morning water landscape" 
      class="bg-img"
      loading="eager"
      decoding="async"
    />  
    <div class="overlay"></div>
  </div>
  
  <div class="container hero-content">
    <div class="hero-text">
      <h1 class="title fade-in-up">Jimmy Pidgeon</h1>
      <p class="tagline fade-in-up delay-100">Author & father, sharing lessons from recovery</p>
      <div class="hero-actions fade-in-up delay-200">
        <a href="https://a.co/d/05W2aYn4" target="_blank" rel="noopener noreferrer" class="btn btn-warm">
          Read the Book
        </a>
        <a href="/about" class="btn btn-hero-secondary">
          About Jimmy
        </a>
      </div>
    </div>
    
    <div class="scroll-indicator fade-in-up delay-400">
      <div class="chevron"></div>
      <div class="chevron"></div>
      <div class="chevron"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    z-index: 0;
    height: 100vh;
    min-height: 580px;
    max-height: 900px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  
  .hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
  }
  
  .bg-img {
    width: 100%;
    height: 110%; /* Slightly taller for parallax room */
    object-fit: cover;
    object-position: center;
    will-change: transform;
  }
  
  .overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    /* Gentle vignette that fades to background color at bottom */
    background: linear-gradient(
      to bottom,
      rgba(255,255,255,0.05) 0%,
      rgba(230,238,245,0.3) 30%,
      rgba(225,235,244,0.65) 70%,
      var(--color-bg) 100%
    );
  }
  
  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    z-index: 1;
    position: relative;
    width: 100%;
    padding-top: 80px; /* Account for fixed header */
  }
  
  .hero-text {
    max-width: 700px;
  }
  
  .title {
    color: var(--color-primary-dark);
    font-size: clamp(3.5rem, 8vw, 6rem);
    margin-bottom: var(--space-2);
    letter-spacing: -0.02em;
    text-shadow: 0 2px 16px rgba(255,255,255,0.9);
    line-height: 1.05;
  }
  
  .tagline {
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    color: var(--color-text);
    font-weight: 400;
    margin-bottom: var(--space-8);
    opacity: 0;
    animation: fadeInUp 0.8s ease-out 100ms forwards;
    text-shadow: 0 1px 8px rgba(255,255,255,0.8);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeInUp 0.8s ease-out 200ms forwards;
  }

  .btn-hero-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius);
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 1rem;
    text-decoration: none;
    letter-spacing: 0.01em;
    background-color: rgba(255, 255, 255, 0.7);
    color: var(--color-primary-dark);
    border: 1.5px solid rgba(255,255,255,0.8);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: all 0.3s ease;
  }

  .btn-hero-secondary:hover {
    background-color: rgba(255, 255, 255, 0.95);
    color: var(--color-primary-dark);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  
  .scroll-indicator {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    width: 28px;
    height: 48px;
    opacity: 0;
    animation: fadeInUp 0.8s ease-out 600ms forwards;
  }
  
  .chevron {
    position: absolute;
    width: 28px;
    height: 8px;
    opacity: 0;
    transform: scale3d(0.5, 0.5, 0.5);
    animation: move 3s ease-out infinite;
  }
  
  .chevron:first-child  { animation: move 3s ease-out 1s infinite; }
  .chevron:nth-child(2) { animation: move 3s ease-out 2s infinite; }
  
  .chevron:before,
  .chevron:after {
    content: ' ';
    position: absolute;
    top: 0;
    height: 100%;
    width: 51%;
    background: var(--color-primary);
  }
  
  .chevron:before {
    left: 0;
    transform: skew(0deg, 30deg);
  }
  
  .chevron:after {
    right: 0;
    width: 50%;
    transform: skew(0deg, -30deg);
  }
  
  @keyframes move {
    25% { opacity: 1; }
    33% { opacity: 1; transform: translateY(30px); }
    67% { opacity: 1; transform: translateY(40px); }
    100% {
      opacity: 0;
      transform: translateY(55px) scale3d(0.5, 0.5, 0.5);
    }
  }

  @media (max-width: 768px) {
    .hero {
      height: 85vh;
      max-height: 700px;
    }

    .hero-actions {
      flex-direction: column;
      align-items: center;
      gap: var(--space-3);
    }

    .hero-actions .btn-warm,
    .hero-actions .btn-hero-secondary {
      width: 220px;
    }

    .scroll-indicator {
      bottom: 24px;
    }
  }
</style>

<script>
  // Subtle parallax on scroll
  const heroBg = document.querySelector('.hero .bg-img') as HTMLElement | null;
  if (heroBg) {
    window.addEventListener('scroll', () => {
      const scrolled = window.scrollY;
      if (scrolled < window.innerHeight) {
        heroBg.style.transform = `translateY(${scrolled * 0.3}px)`;
      }
    }, { passive: true });
  }
</script>
