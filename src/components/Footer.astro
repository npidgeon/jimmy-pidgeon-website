---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-content">
    <div class="footer-brand">
      <h3>Jimmy Pidgeon</h3>
      <p>Author and father, sharing lessons from recovery.</p>
      <p class="copyright">&copy; {currentYear} Jimmy Pidgeon. All rights reserved.</p>
    </div>
    
    <div class="footer-links">
      <h4>Quick Links</h4>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/books">Books</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </div>
    
    <div class="footer-connect">
      <h4>Connect</h4>
      <a href="https://instagram.com/jcp83recovery" target="_blank" rel="noopener noreferrer" class="social-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        @jcp83recovery
      </a>
      <a href="https://www.linkedin.com/in/jimmy-pidgeon-193b08199/" target="_blank" rel="noopener noreferrer" class="social-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
        LinkedIn
      </a>
      <a href="/contact" class="social-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
        Get in touch
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-primary-dark);
    color: white;
    padding: var(--space-8) 0 var(--space-8);
    position: relative;
    margin-top: auto;
  }
  
  .footer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
  }
  
  .footer-content {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-8);
  }
  
  .footer h3 {
    color: white;
    margin-bottom: var(--space-2);
  }
  
  .footer h4 {
    color: var(--color-accent-light);
    font-family: var(--font-body);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-4);
  }
  
  .footer p {
    color: rgba(255, 255, 255, 0.8);
  }
  
  .copyright {
    margin-top: var(--space-6);
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.6) !important;
  }
  
  .footer-links ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  
  .footer a {
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
  }
  
  .footer a:hover {
    color: white;
  }
  
  .footer-connect {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  
  .social-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  
  @media (max-width: 768px) {
    .footer-content {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }
</style>
