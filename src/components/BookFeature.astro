---
import { Image } from 'astro:assets';
import coverImg from '../assets/images/cover.png';
---

<section class="book-feature section-padding">
  <div class="container">
    <div class="feature-grid">
      <div class="book-image-container scroll-reveal-left">
        <div class="book-wrapper">
          <Image 
            src={coverImg}
            alt="From the Streets to the Steps — One Day at a Time, a memoir by Jimmy Pidgeon"
            class="book-cover"
            widths={[300, 500, 700]}
            sizes="(max-width: 600px) 280px, (max-width: 900px) 320px, 420px"
            quality={85}
          />
        </div>
      </div>
      
      <div class="book-content scroll-reveal-right">
        <span class="eyebrow">New Release · 2026</span>
        <h2>From the Streets to the Steps</h2>
        <h3 class="subtitle">One Day at a Time – A Memoir</h3>

        <!-- Star rating -->
        <div class="rating" aria-label="Highly rated on Amazon">
          <span class="stars" aria-hidden="true">★★★★★</span>
          <span class="rating-text">Readers love it</span>
        </div>
        
        <div class="metadata">
          <p><strong>By:</strong> Jimmy Pidgeon with Ben Rose</p>
          <p><strong>Published:</strong> January 6, 2026</p>
        </div>
        
        <p class="description">
          A raw and unflinching memoir chronicling Jimmy's journey from the depths of addiction through the transformative power of recovery. Part personal story, part guide for anyone seeking a way out, this book shows that true change is possible—one day at a time.
        </p>
        
        <div class="actions">
          <a href="https://a.co/d/05W2aYn4" target="_blank" rel="noopener noreferrer" class="btn btn-warm">
            Buy on Amazon
          </a>
          <a href="/books" class="btn btn-secondary">
            Learn More
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .section-padding {
    padding: var(--space-16) 0;
    background-color: var(--color-surface);
  }
  
  .feature-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: var(--space-12);
    align-items: center;
  }
  
  .book-image-container {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .book-wrapper {
    position: relative;
    display: inline-block;
    filter: drop-shadow(0 20px 48px rgba(0, 0, 0, 0.22));
    transition: filter 0.4s ease, transform 0.4s ease;
  }

  .book-wrapper:hover {
    filter: drop-shadow(0 28px 56px rgba(0, 0, 0, 0.28));
    transform: translateY(-8px) rotate(-1deg);
  }
  
  .book-cover {
    max-height: 480px;
    width: auto;
    border-radius: 4px;
    display: block;
  }
  
  .eyebrow {
    display: inline-block;
    color: var(--color-warm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.8rem;
    margin-bottom: var(--space-3);
    background-color: hsl(38, 65%, 96%);
    padding: 0.25rem 0.75rem;
    border-radius: 100px;
  }

  h2 {
    color: var(--color-primary-dark);
    margin-bottom: var(--space-1);
  }
  
  .subtitle {
    color: var(--color-text-muted);
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 1.1rem;
    margin-top: -0.25rem;
    margin-bottom: var(--space-4);
  }

  /* Star rating */
  .rating {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: var(--space-4);
  }

  .stars {
    color: var(--color-warm);
    font-size: 1.1rem;
    letter-spacing: 0.05em;
  }

  .rating-text {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-style: italic;
  }
  
  .metadata {
    margin-bottom: var(--space-5);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    border-left: 3px solid var(--color-warm-light);
    padding-left: var(--space-4);
  }
  
  .metadata p {
    margin-bottom: var(--space-1);
    color: var(--color-text);
  }
  
  .description {
    font-size: 1.1rem;
    margin-bottom: var(--space-8);
    color: var(--color-text);
    line-height: 1.75;
  }
  
  .actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
  
  @media (max-width: 900px) {
    .feature-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: var(--space-8);
    }

    .metadata {
      border-left: none;
      padding-left: 0;
    }

    .rating {
      justify-content: center;
    }
    
    .actions {
      justify-content: center;
    }
  }
</style>
