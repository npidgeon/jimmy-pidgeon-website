<section class="instagram-section section-padding" id="instagram-feed">
  <div class="container">
    <div class="section-header scroll-reveal">
      <span class="section-label">Follow the Journey</span>
      <h2>Daily Lessons & Recovery</h2>
      <p class="section-sub">Reflections and moments shared daily on Instagram at <a href="https://instagram.com/jcp83recovery" target="_blank" rel="noopener noreferrer">@jcp83recovery</a></p>
    </div>
    
    <div class="feed-grid scroll-reveal delay-100">
      <!-- Post 1 -->
      <blockquote
        class="instagram-media"
        data-instgrm-permalink="https://www.instagram.com/p/CyEdXStujCh/?utm_source=ig_embed&amp;utm_campaign=loading"
        data-instgrm-version="14"
      ></blockquote>

      <!-- Post 2 -->
      <blockquote
        class="instagram-media"
        data-instgrm-permalink="https://www.instagram.com/p/DVuC4HqDQr_/?utm_source=ig_embed&amp;utm_campaign=loading"
        data-instgrm-version="14"
      ></blockquote>

      <!-- Post 3 -->
      <blockquote
        class="instagram-media"
        data-instgrm-permalink="https://www.instagram.com/p/DUoAu1jDAcJ/?utm_source=ig_embed&amp;utm_campaign=loading"
        data-instgrm-version="14"
      ></blockquote>
    </div>
    
    <div class="action-container scroll-reveal delay-200">
      <a href="https://instagram.com/jcp83recovery" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
        Visit Instagram Profile
      </a>
    </div>
  </div>
</section>

<script async src="//www.instagram.com/embed.js"></script>

<style>
  .section-padding {
    padding: var(--space-16) 0;
    background: linear-gradient(
      180deg,
      var(--color-bg-alt) 0%,
      hsl(210, 20%, 94%) 100%
    );
    position: relative;
  }

  /* Subtle top wave decoration */
  .section-padding::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--color-primary-light), var(--color-warm-light), var(--color-accent-light));
  }
  
  .section-header {
    text-align: center;
    margin-bottom: var(--space-10);
  }

  .section-label {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-primary);
    margin-bottom: var(--space-3);
  }

  .section-header h2 {
    margin-bottom: var(--space-3);
    color: var(--color-primary-dark);
  }

  .section-sub {
    color: var(--color-text-muted);
    font-size: 1rem;
    max-width: 480px;
    margin: 0 auto;
  }

  .section-sub a {
    color: var(--color-primary);
    font-weight: 500;
  }
  
  .feed-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
    justify-items: center;
    margin-bottom: var(--space-10);
  }

  /* Override Instagram embed default styles to fit grid */
  .feed-grid :global(.instagram-media) {
    min-width: 0 !important;
    max-width: 100% !important;
    width: 100% !important;
    margin: 0 !important;
  }
  
  .action-container {
    text-align: center;
  }
  
  @media (max-width: 1024px) {
    .feed-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .feed-grid :global(.instagram-media:last-child) {
      display: none;
    }
  }
  
  @media (max-width: 640px) {
    .feed-grid {
      grid-template-columns: 1fr;
    }
    .feed-grid :global(.instagram-media:last-child) {
      display: block;
    }
  }
</style>
